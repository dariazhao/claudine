  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "build": "prisma generate && node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "db:migrate": "prisma migrate dev",
