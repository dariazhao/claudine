    "iron-session": "^8.0.4",
    "next": "16.1.6",
    "pg": "^8.19.0",
    "prisma": "^7.4.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.5.0",
    "twilio": "^5.12.2"
  },
  "devDependencies": {
